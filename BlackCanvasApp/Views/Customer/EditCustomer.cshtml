@{
    ViewData["Title"] = "Editar Cliente";
}

<h2 class="page-title">Editar Cliente</h2>

<div class="card shadow-soft p-4">

    <form>

        <div class="mb-3">
            <label class="form-label">Nombre</label>
            <input class="form-control" value="Juan Pérez" />
        </div>

        <div class="mb-3">
            <label class="form-label">Email</label>
            <input class="form-control" value="juan@email.com" />
        </div>

        <div class="mb-3">
            <label class="form-label">Teléfono</label>
            <input class="form-control" value="809-000-0000" />
        </div>

        <div class="mb-3">
            <label class="form-label">Dirección</label>
            <textarea class="form-control">Santo Domingo</textarea>
        </div>

        <div class="d-flex justify-content-end">
            <a  class="btn btn-secondary me-2" asp-controller="Customer" asp-action="CustomerList">Cancelar</a>
            <button class="btn btn-primary">Actualizar</button>
        </div>

    </form>

</div>