@using BlackCanvasApp.DTOs
@{
    ViewData["Title"] = "Clientes";
}
@model List<CustomerDto>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="page-title">Clientes</h2>

    <a class="btn btn-primary" asp-controller="Customer" asp-action="CreateCustomer">
        <i class="bi bi-plus-circle"></i> Nuevo Cliente
    </a>
</div>

<div class="card shadow-soft p-3">

    <!-- Buscador -->
    <div class="mb-3">
        <input type="text" class="form-control" placeholder="Buscar cliente..." />
    </div>

    <!-- Tabla -->
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Nombre</th>
                <th>Apellido</th>
                <th>Teléfono</th>
                <th>Dirección</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>

        <tbody>
            @foreach(var item in Model)
            {
            <tr>
                <td>@item.Name</td>
                <td>@item.lastName</td>
                <td>@item.Phone</td>
                <td>@item.Address</td>

                <td class="text-end">
                    <a class="btn btn-sm btn-warning" asp-controller="Customer" asp-action="EditCustomer">
                        <i class="bi bi-pencil"></i>
                    </a>

                    <a  class="btn btn-sm btn-danger" asp-controller="Customer" asp-action="DeleteCustomer">
                        <i class="bi bi-trash"></i>
                    </a>
                </td>
            </tr>
            }
        </tbody>
    </table>

</div>