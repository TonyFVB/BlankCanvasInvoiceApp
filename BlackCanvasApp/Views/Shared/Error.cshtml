@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
    var color = Model.StatusCode switch
    {
        401 => "info",
        403 => "secondary",
        404 => "warning",
        _ => "danger"
    };

}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 80vh;">
    <div class="card shadow-lg border-0 p-5 text-center">

        <!-- Icono -->
        <div class="mb-4">
            <i class="bi bi-exclamation-triangle-fill text-@color" style="font-size: 4rem;"></i>
        </div>

        <!-- Código de error -->
        <h1 class="display-4 fw-bold">
            @Model.StatusCode
        </h1>

        <!-- Mensaje amigable -->
        <h3 class="mb-3">
            @Model.Message
        </h3>

        <p class="text-muted mb-4">
            Lo sentimos, ocurrió un problema inesperado.
            Puedes intentar nuevamente o volver al inicio.
        </p>

        <!-- Botones -->
        <div class="d-flex justify-content-center gap-3">
            <a href="/" class="btn btn-primary">
                Ir al inicio
            </a>

            <button onclick="location.reload()" class="btn btn-outline-secondary">
                Reintentar
            </button>
        </div>

        <!-- Detalles técnicos (solo desarrollo) -->
        @if (Model.ShowDetails && !string.IsNullOrEmpty(Model.Details))
        {
            <div class="mt-5 text-start">
                <div class="alert alert-warning">
                    <strong>Detalle técnico:</strong>
                    <pre class="mb-0">@Model.Details</pre>
                </div>
            </div>
        }

        <!-- Request ID -->
        @if (Model.ShowRequestId)
        {
            <div class="mt-3 text-muted">
                <small>Request ID: @Model.RequestId</small>
            </div>
        }

    </div>
</div>
